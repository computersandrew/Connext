# ─── Transit API Keys ───────────────────────────
# Register for free at each agency's developer portal
MTA_API_KEY=
MBTA_API_KEY=
CTA_API_KEY=
# SEPTA requires no key

# ─── Redis ───────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── PostgreSQL ──────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=connext
PG_USER=connext
PG_PASSWORD=connext

# ─── Logging ─────────────────────────────────────
LOG_LEVEL=info
